# ===========================================================================
#  TEMPLATE bien moi truong - COPY thanh `.env` va dien gia tri that.
#  File .env that KHONG duoc commit (da nam trong .gitignore).
#  Compose tu doc file .env nay; spring-dotenv cung nap khi chay app local.
# ===========================================================================

# ---------- PostgreSQL (container trong docker-compose) ----------
POSTGRES_DB=vsl_db
POSTGRES_USER=vsl_user
POSTGRES_PASSWORD=
POSTGRES_PORT=5432

# ---------- pgAdmin (container trong docker-compose) ----------
PGADMIN_EMAIL=admin@vsl.local
PGADMIN_PASSWORD=

# ---------- App datasource ----------
# Local (app ngoai docker) tro localhost; trong compose se duoc ghi de sang host "postgres".
DB_URL=jdbc:postgresql://localhost:5432/vsl_db
DB_USERNAME=vsl_user
DB_PASSWORD=

# ---------- JWT ----------
# Tao secret moi: openssl rand -base64 64
JWT_SECRET=
JWT_ACCESS_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=604800000

# ---------- Server ----------
SERVER_PORT=8080

# ---------- MinIO Object Storage ----------
# MINIO_ENDPOINT    : URL backend dung de ket noi (dung "http://minio:9000" khi chay trong Docker)
# MINIO_PUBLIC_ENDPOINT: URL browser dung de stream video (dung localhost khi dev local)
MINIO_ENDPOINT=http://localhost:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=changeme_minio_secret_min12chars

# ---------- AI Model ----------
# Dat file mvitv2_small.onnx (135MB) vao thu muc models/ tai goc project
# Docker Compose se mount ./models -> /app/models (read-only)
AI_MODEL_PATH=./models/mvitv2_small.onnx
